{% schema %}
{
  "name": "Leave a Review Form",
  "target": "section",
  "stylesheet": "empire.css",
  "settings": [
    { "type": "header", "content": "Button" },
    { "type": "text",   "id": "btn_label",  "label": "Button Label", "default": "Write a Review" },
    { "type": "color",  "id": "btn_bg",     "label": "Button Background", "default": "#111111" },
    { "type": "color",  "id": "btn_text",   "label": "Button Text Color",  "default": "#ffffff" },
    { "type": "range",  "id": "btn_radius", "min": 0, "max": 50, "step": 1, "unit": "px", "label": "Button Radius", "default": 8 },
    { "type": "select", "id": "btn_size",   "label": "Button Size", "options": [
        { "value": "sm",  "label": "Small" },
        { "value": "md",  "label": "Medium" },
        { "value": "lg",  "label": "Large" }
    ], "default": "md" },

    { "type": "header", "content": "Modal Content" },
    { "type": "text",   "id": "modal_title", "label": "Modal Heading", "default": "Share Your Experience" },
    { "type": "text",   "id": "modal_sub",   "label": "Sub-heading",   "default": "Help others by leaving a review." },
    { "type": "color",  "id": "star_color",  "label": "Star Color",    "default": "#fbbf24" },
    { "type": "checkbox","id":"ask_photos",  "label": "Allow Photo Upload (URL)",  "default": false },

    { "type": "header", "content": "Success Message" },
    { "type": "text",   "id": "success_msg", "label": "Thank You Message", "default": "🎉 Thank you! Your review has been submitted for approval." }
  ]
}
{% endschema %}

<div class="empire-review-form-wrap"
     data-product-id="{{ product.id }}"
     data-product-title="{{ product.title | escape }}"
     data-shop="{{ shop.permanent_domain }}"
     data-app-url="{{ shop.metafields.empire.app_url | default: '' }}"
     data-star-color="{{ block.settings.star_color }}"
     data-ask-photos="{{ block.settings.ask_photos }}"
     data-success-msg="{{ block.settings.success_msg | escape }}"
>
  <button class="empire-review-btn empire-review-btn--{{ block.settings.btn_size }}" onclick="empireOpenReviewForm(this)"
    style="
      background: {{ block.settings.btn_bg }};
      color: {{ block.settings.btn_text }};
      border-radius: {{ block.settings.btn_radius }}px;
    "
  >
    {% render 'empire-pen-icon' %}
    {{ block.settings.btn_label }}
  </button>

  <!-- MODAL OVERLAY -->
  <div class="empire-form-overlay" id="empire-review-modal" style="display:none;">
    <div class="empire-form-modal">
      <button class="empire-form-close" onclick="empireCloseReviewForm()" aria-label="Close">✕</button>

      <div class="empire-form-header">
        <div style="font-size:2.5rem;">✍️</div>
        <h2 class="empire-form-title">{{ block.settings.modal_title }}</h2>
        <p class="empire-form-sub">{{ block.settings.modal_sub }}</p>
      </div>

      <!-- STAR PICKER -->
      <div class="empire-star-picker" id="empire-star-picker" data-rating="0">
        {% for i in (1..5) %}
          <svg class="empire-pick-star" data-val="{{ i }}" viewBox="0 0 24 24" fill="#e5e7eb"
               onclick="empirePickStar(this)"
               onmouseover="empireHoverStar(this)"
               onmouseout="empireResetStars()">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
        {% endfor %}
        <span class="empire-star-label" id="empire-star-label"></span>
      </div>

      <!-- FORM -->
      <form class="empire-review-form" id="empire-review-form" onsubmit="empireSubmitReview(event, this)">
        <input type="hidden" name="shop"      value="{{ shop.permanent_domain }}" />
        <input type="hidden" name="productId" value="{{ product.id }}" />
        <input type="hidden" name="rating"    id="empire-rating-input" value="0" />

        <div class="empire-form-row">
          <label class="empire-label">Your Name *</label>
          <input class="empire-input" type="text"  name="author"  placeholder="Jane D." required />
        </div>

        <div class="empire-form-row">
          <label class="empire-label">Email (private)</label>
          <input class="empire-input" type="email" name="email"   placeholder="you@email.com" />
        </div>

        <div class="empire-form-row">
          <label class="empire-label">Review Title</label>
          <input class="empire-input" type="text"  name="title"   placeholder="Summarise your experience" />
        </div>

        <div class="empire-form-row">
          <label class="empire-label">Your Review *</label>
          <textarea class="empire-input empire-textarea" name="body" rows="4" placeholder="Tell others what you think…" required></textarea>
        </div>

        {% if block.settings.ask_photos %}
        <div class="empire-form-row">
          <label class="empire-label">Photo URL (optional)</label>
          <input class="empire-input" type="url" name="media_urls" placeholder="https://…" />
        </div>
        {% endif %}

        <div id="empire-form-error"  class="empire-form-msg error"   style="display:none;"></div>
        <div id="empire-form-success"class="empire-form-msg success" style="display:none;"></div>

        <button type="submit" class="empire-submit-btn"
          id="empire-submit-btn"
          style="background: {{ block.settings.btn_bg }}; color: {{ block.settings.btn_text }}; border-radius: {{ block.settings.btn_radius }}px;"
        >
          Submit Review →
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  /* Button */
  .empire-review-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-weight: 600; cursor: pointer; border: none;
    font-family: inherit; letter-spacing: 0.01em;
    transition: opacity 0.2s, transform 0.2s;
  }
  .empire-review-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .empire-review-btn--sm { padding: 8px 18px;  font-size: 0.85rem; }
  .empire-review-btn--md { padding: 12px 24px; font-size: 0.95rem; }
  .empire-review-btn--lg { padding: 16px 32px; font-size: 1.1rem; }

  /* Overlay + Modal */
  .empire-form-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
  }
  .empire-form-modal {
    background: #fff; border-radius: 24px;
    padding: 2.5rem 2rem;
    width: 100%; max-width: 480px;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.25);
    max-height: 92vh; overflow-y: auto;
    animation: empire-modal-in 0.25s ease;
  }
  @keyframes empire-modal-in {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1); }
  }
  .empire-form-close {
    position: absolute; top: 18px; right: 20px;
    background: #f1f5f9; border: none; border-radius: 50%;
    width: 32px; height: 32px; cursor: pointer;
    font-size: 1rem; transition: background 0.2s;
  }
  .empire-form-close:hover { background: #e2e8f0; }
  .empire-form-header { text-align: center; margin-bottom: 1.5rem; }
  .empire-form-title  { font-size: 1.5rem; font-weight: 800; margin: 0.4rem 0 0.2rem; }
  .empire-form-sub    { opacity: 0.55; font-size: 0.9rem; margin: 0; }

  /* Stars */
  .empire-star-picker {
    display: flex; gap: 6px; align-items: center;
    justify-content: center; margin-bottom: 1.5rem;
  }
  .empire-pick-star { width: 36px; height: 36px; cursor: pointer; transition: transform 0.15s; }
  .empire-pick-star:hover { transform: scale(1.15); }
  .empire-star-label { font-size: 0.85rem; opacity: 0.6; margin-left: 6px; width: 80px; }

  /* Form fields */
  .empire-form-row  { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
  .empire-label     { font-size: 0.85rem; font-weight: 600; opacity: 0.75; }
  .empire-input {
    width: 100%; padding: 10px 14px;
    border: 1px solid #e2e8f0; border-radius: 10px;
    font-family: inherit; font-size: 0.95rem;
    transition: border-color 0.2s; outline: none; box-sizing: border-box;
  }
  .empire-input:focus { border-color: #94a3b8; }
  .empire-textarea  { resize: vertical; min-height: 100px; }
  .empire-submit-btn {
    width: 100%; padding: 14px; font-size: 1rem;
    font-weight: 700; border: none; cursor: pointer;
    font-family: inherit; transition: opacity 0.2s, transform 0.2s;
  }
  .empire-submit-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .empire-form-msg { padding: 10px 14px; border-radius: 10px; font-size: 0.9rem; margin-bottom: 12px; }
  .empire-form-msg.error   { background: #fef2f2; color: #b91c1c; }
  .empire-form-msg.success { background: #ecfdf5; color: #166534; }
</style>

<script>
(function() {
  var LABELS = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
  var starColor = '{{ block.settings.star_color }}';
  var successMsg = '{{ block.settings.success_msg | escape }}';

  window.empireOpenReviewForm = function(btn) {
    document.getElementById('empire-review-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  window.empireCloseReviewForm = function() {
    document.getElementById('empire-review-modal').style.display = 'none';
    document.body.style.overflow = '';
  };
  // Close on backdrop click
  document.getElementById('empire-review-modal').addEventListener('click', function(e) {
    if (e.target === this) empireCloseReviewForm();
  });

  window.empireHoverStar = function(star) {
    var val = parseInt(star.dataset.val);
    document.querySelectorAll('.empire-pick-star').forEach(function(s) {
      s.setAttribute('fill', parseInt(s.dataset.val) <= val ? starColor : '#e5e7eb');
    });
    document.getElementById('empire-star-label').textContent = LABELS[val];
  };
  window.empireResetStars = function() {
    var current = parseInt(document.getElementById('empire-star-picker').dataset.rating || '0');
    document.querySelectorAll('.empire-pick-star').forEach(function(s) {
      s.setAttribute('fill', parseInt(s.dataset.val) <= current ? starColor : '#e5e7eb');
    });
    document.getElementById('empire-star-label').textContent = current > 0 ? LABELS[current] : '';
  };
  window.empirePickStar = function(star) {
    var val = parseInt(star.dataset.val);
    document.getElementById('empire-star-picker').dataset.rating = val;
    document.getElementById('empire-rating-input').value = val;
    empireResetStars();
  };

  window.empireSubmitReview = function(e, form) {
    e.preventDefault();
    var rating = parseInt(document.getElementById('empire-rating-input').value);
    var errEl  = document.getElementById('empire-form-error');
    var sucEl  = document.getElementById('empire-form-success');
    var btn    = document.getElementById('empire-submit-btn');

    errEl.style.display = 'none';
    sucEl.style.display = 'none';

    if (!rating || rating < 1) {
      errEl.textContent = 'Please select a star rating.';
      errEl.style.display = 'block';
      return;
    }

    var wrap   = form.closest('.empire-review-form-wrap');
    var appUrl = (wrap.dataset.appUrl || '').trim() ||
                 (window.EMPIRE_APP_URL || '') ||
                 'https://empire-reviews.vercel.app';

    btn.textContent = 'Submitting…';
    btn.disabled = true;

    var data = new FormData(form);

    fetch(appUrl + '/api/reviews', {
      method: 'POST',
      body: data
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        form.style.display = 'none';
        sucEl.textContent  = successMsg || '🎉 Thank you! Your review has been submitted.';
        sucEl.style.display = 'block';
        setTimeout(empireCloseReviewForm, 3500);
      } else {
        throw new Error(res.error || 'Submission failed');
      }
    })
    .catch(function(err) {
      btn.textContent = 'Submit Review →';
      btn.disabled = false;
      errEl.textContent = err.message || 'Something went wrong. Please try again.';
      errEl.style.display = 'block';
    });
  };
})();
</script>
