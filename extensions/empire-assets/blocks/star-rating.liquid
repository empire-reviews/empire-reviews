<div class="empire-star-rating" 
     data-product-id="{{ product.id }}"
     data-shop-domain="{{ shop.domain }}"
     style="--star-color: {{ block.settings.star_color }}; --text-color: {{ block.settings.text_color }}; --star-size: {{ block.settings.star_size }}px; --text-size: {{ block.settings.text_size }}px; justify-content: {{ block.settings.alignment }};">
    
    <div class="empire-stars-skeleton">
        <span class="empire-skeleton-star">★</span>
        <span class="empire-skeleton-star">★</span>
        <span class="empire-skeleton-star">★</span>
        <span class="empire-skeleton-star">★</span>
        <span class="empire-skeleton-star">★</span>
    </div>
    <span class="empire-rating-text-skeleton"></span>
</div>

{% schema %}
{
  "name": "Empire Star Rating",
  "target": "section",
  "stylesheet": "empire-widgets.css",
  "javascript": "empire-widgets.js",
  "templates": ["product"],
  "settings": [
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#f59e0b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#475569"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "star_size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Star Size",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Text Size",
      "default": 14
    }
  ]
}
{% endschema %}
