# Shopify App Credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SCOPES=write_products,read_products,write_script_tags,read_script_tags,read_orders,read_all_orders
SHOPIFY_APP_URL=https://your-app-url.vercel.app

# Database (PostgreSQL required for production)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Email Provider (Resend)
RESEND_API_KEY=re_your_resend_api_key
verified_domain=yourdomain.com

# Security Secrets (Generate with: openssl rand -hex 32)
CRON_SECRET=your_secure_random_string_here
UNSUBSCRIBE_SECRET=another_secure_random_string_here

# VIP / Referral Codes (comma-separated) — grants lifetime Pro access without Shopify billing
# Example: VALID_VIP_CODES=code1,partner-store-abc,vip2026
VALID_VIP_CODES=

# Set to "true" to use Shopify test charges instead of real billing
BILLING_TEST_MODE=false

# Error Tracking (Recommended in production)
SENTRY_DSN=https://your-sentry-dsn@o0000000.ingest.sentry.io/0000000

# Logging / Misc
kafkajs=silent

# Environment
NODE_ENV=production
