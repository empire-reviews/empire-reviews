{% schema %}
{
  "name": "Review Summary Bar",
  "target": "section",
  "stylesheet": "empire.css",
  "javascript": "empire_summary_bar.js",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Layout Style", "options": [
        { "value": "horizontal", "label": "Horizontal (Compact)" },
        { "value": "vertical",   "label": "Vertical (Full Breakdown)" }
    ], "default": "vertical" },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Right" }
    ], "default": "flex-start" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "star_color", "label": "Star Color",      "default": "#fbbf24" },
    { "type": "color", "id": "bar_color",  "label": "Bar Fill Color",  "default": "#fbbf24" },
    { "type": "color", "id": "text_color", "label": "Text Color",      "default": "#111111" },
    { "type": "color", "id": "bg_color",   "label": "Background",      "default": "#ffffff" },
    { "type": "range", "id": "font_size",  "min": 12, "max": 22, "step": 1, "unit": "px", "label": "Font Size", "default": 14 },

    { "type": "header", "content": "Content" },
    { "type": "checkbox", "id": "show_breakdown", "label": "Show Rating Breakdown Bars",  "default": true  },
    { "type": "checkbox", "id": "show_verified",  "label": "Show 'Verified Buyers' Badge","default": true  },
    { "type": "text",     "id": "empty_text",     "label": "No Reviews Text",
      "default": "Be the first to review this product" }
  ]
}
{% endschema %}

<div class="empire-summary-bar"
     data-product-id="{{ product.id }}"
     data-shop="{{ shop.permanent_domain }}"
     data-app-url="{{ shop.metafields.empire.app_url | default: '' }}"
     data-layout="{{ block.settings.layout }}"
     data-show-breakdown="{{ block.settings.show_breakdown }}"
     data-show-verified="{{ block.settings.show_verified }}"
     data-empty-text="{{ block.settings.empty_text }}"
     style="
       --esb-star:  {{ block.settings.star_color }};
       --esb-bar:   {{ block.settings.bar_color }};
       --esb-text:  {{ block.settings.text_color }};
       --esb-bg:    {{ block.settings.bg_color }};
       --esb-fs:    {{ block.settings.font_size }}px;
       --esb-align: {{ block.settings.alignment }};
       font-family: inherit;
       color: {{ block.settings.text_color }};
       font-size: {{ block.settings.font_size }}px;
       background: {{ block.settings.bg_color }};
       padding: 12px 0;
       width: 100%;
     "
>
  <div class="esb-loading" style="opacity:0.4;font-size:0.85em;">Loading reviews…</div>
</div>

<style>
  .esb-loading { opacity: 0.4; font-size: 0.85em; }

  .esb-horizontal {
    display: inline-flex; align-items: center; gap: 10px; flex-wrap: wrap;
    justify-content: var(--esb-align); width: 100%;
  }
  .esb-score-big { font-size: 2.2em; font-weight: 800; line-height: 1; color: var(--esb-text); }
  .esb-stars-row { display: inline-flex; gap: 2px; align-items: center; color: var(--esb-star); line-height: 0; }
  .esb-count-text { opacity: 0.6; font-size: 0.9em; }

  .esb-vertical {
    display: flex; gap: 28px; align-items: flex-start; flex-wrap: wrap;
    justify-content: var(--esb-align); width: 100%;
  }
  .esb-left { display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 80px; }
  .esb-right { flex: 1; min-width: 160px; display: flex; flex-direction: column; gap: 5px; }

  .esb-bar-row { display: flex; align-items: center; gap: 8px; font-size: 0.85em; }
  .esb-bar-label { min-width: 14px; text-align: right; opacity: 0.7; }
  .esb-bar-track { flex: 1; height: 8px; background: #e5e7eb; border-radius: 99px; overflow: hidden; }
  .esb-bar-fill  { height: 100%; background: var(--esb-bar); border-radius: 99px; transition: width 0.6s ease; }
  .esb-bar-count { min-width: 24px; opacity: 0.55; }

  .esb-verified {
    display: inline-flex; align-items: center; gap: 4px; margin-top: 4px;
    background: #dcfce7; color: #166534; border-radius: 99px;
    padding: 2px 10px; font-size: 0.78em; font-weight: 600;
  }
</style>
