<div class="empire-review-carousel-section" data-shop-domain="{{ shop.domain }}" style="
    --empire-carousel-bg: {{ block.settings.bg_color }};
    --empire-carousel-text: {{ block.settings.text_color }};
    --empire-carousel-primary: {{ block.settings.primary_color }};
    --empire-carousel-star-size: {{ block.settings.star_size }}px;
    --star-size: {{ block.settings.star_size }}px;
    --empire-carousel-text-size: {{ block.settings.text_size }}px;
    --empire-card-pt: {{ block.settings.card_padding_top }}px;
    --empire-card-pb: {{ block.settings.card_padding_bottom }}px;
    background-color: var(--empire-carousel-bg);
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px 0;
">
    <div class="empire-carousel-container">
        <div class="empire-carousel-header">
            <h4 class="empire-carousel-subtitle" style="color: {{ block.settings.subtitle_color }}">{{ block.settings.subtitle }}</h4>
            <h2 class="empire-carousel-title" style="color: var(--empire-carousel-text)">{{ block.settings.title }}</h2>
        </div>
        
        <div class="empire-carousel-wrapper">
            <div class="empire-carousel-track" id="empire-carousel-track_{{ block.id }}">
                <div class="empire-carousel-loading" style="padding: 40px; text-align: center; width: 100%;">
                    <div class="empire-spinner" style="border-top-color: var(--empire-carousel-primary)"></div>
                </div>
            </div>
            
            <div class="empire-carousel-nav-row">
                <button class="empire-carousel-nav empire-carousel-prev" aria-label="Previous Review">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                
                <div class="empire-carousel-dots" id="empire-carousel-dots_{{ block.id }}"></div>
                
                <button class="empire-carousel-nav empire-carousel-next" aria-label="Next Review">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Empire Review Carousel",
  "target": "section",
  "stylesheet": "empire-widgets.css",
  "javascript": "empire-widgets.js",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Customer Reviews"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Brand Color (Stars & Accents)",
      "default": "#f59e0b"
    },
    {
      "type": "range",
      "id": "star_size",
      "min": 14,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Star Size",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Card Box Padding"
    },
    {
      "type": "range",
      "id": "card_padding_top",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Card Upper Padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding_bottom",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Card Lower Padding",
      "default": 32
    }
  ]
}
{% endschema %}
